# ══════════════════════════════════════════════════════════════════════
#  FleetOps · .env — Producción
#  Copiá como .env y completá antes de levantar
# ══════════════════════════════════════════════════════════════════════

# ── Dominio ────────────────────────────────────────────────────────────
# Sin https:// ni slash final
DOMAIN=panel.monitoreocinexo.com.ar

# ── PostgreSQL ─────────────────────────────────────────────────────────
PGDATABASE=fleetops
PGUSER=fleetops
PGPASSWORD=CAMBIA_ESTO_password_muy_seguro

# ── Seguridad ──────────────────────────────────────────────────────────
# Generá con: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_jwt_secret_largo

# Exactamente 32 caracteres para AES-256
# Generá con: openssl rand -hex 16  (da 32 chars hex)
ENC_KEY=CAMBIA_ESTO_32chars_exactos!!!

# Password del usuario admin (solo aplica en el primer inicio)
ADMIN_PASSWORD=CAMBIA_ESTO_admin_pass_seguro

# ── Cloudflare Tunnel ──────────────────────────────────────────────────
# Token obtenido con: cloudflared tunnel token fleetops
CLOUDFLARE_TUNNEL_TOKEN=PEGAR_TOKEN_AQUI
